{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/style.css",
      "dest": "/static/style.css"
    },
    {
      "src": "/app.js",
      "dest": "/static/app.js"
    },
    {
      "src": "/(.*)",
      "dest": "/static/index.html"
    }
  ]
}
