# ──────────────────────────────────────────────────
# Timidly Inc — AI Lead Generation Pipeline
# Environment Configuration Template
# ──────────────────────────────────────────────────
# Copy this file to `.env` and fill in your credentials:
#   cp .env.example .env
# ──────────────────────────────────────────────────

# Apify API Token (Scraping and Automation Platform)
# Sign up at https://console.apify.com/ → Settings → API tokens
APIFY_API_TOKEN=""

# OpenAI API Key (Language Model for Pitch Generation)
# Generate at https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# Firecrawl API Key (Website Crawling and Markdown Conversion)
# Sign up at https://firecrawl.dev/ → Dashboard → API Keys
FIRECRAWL_API_KEY=""

# SMTP Email Configuration (Gmail example)
# To generate a Gmail App Password:
#   1. Enable 2-Step Verification: https://myaccount.google.com/signinoptions/two-step-verification
#   2. Create App Password: https://myaccount.google.com/apppasswords
#   3. Paste the 16-character password below (no spaces)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
